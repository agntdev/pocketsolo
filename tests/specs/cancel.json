[
  {
    "name": "/cancel shows no active trades",
    "steps": [
      {
        "send": { "text": "/cancel" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No active trades to cancel."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "cancel button shows no active trades",
    "steps": [
      {
        "send": { "callback": "cancel:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "No active trades to cancel."
            }
          }
        ]
      }
    ]
  }
]
